{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "index": {
      "$ref": "#/$defs/__schema0"
    },
    "include_defaults": {
      "$ref": "#/$defs/__schema3"
    },
    "master_timeout": {
      "$ref": "#/$defs/__schema5"
    }
  },
  "required": [
    "index"
  ],
  "additionalProperties": false,
  "id": "IndicesExplainDataLifecycleRequest",
  "$defs": {
    "__schema0": {
      "description": "Comma-separated list of index names to explain",
      "$ref": "#/$defs/Indices"
    },
    "Indices": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema1"
        },
        {
          "$ref": "#/$defs/__schema2"
        }
      ],
      "id": "Indices"
    },
    "__schema1": {
      "$ref": "#/$defs/IndexName"
    },
    "IndexName": {
      "type": "string",
      "id": "IndexName"
    },
    "__schema2": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/IndexName"
      }
    },
    "__schema3": {
      "$ref": "#/$defs/__schema4"
    },
    "__schema4": {
      "type": "boolean",
      "description": "Indicates if the API should return the default values the system uses for the index's lifecycle"
    },
    "__schema5": {
      "$ref": "#/$defs/__schema6"
    },
    "__schema6": {
      "description": "The period to wait for a connection to the master node.",
      "$ref": "#/$defs/Duration"
    },
    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema7"
        },
        {
          "$ref": "#/$defs/__schema8"
        },
        {
          "$ref": "#/$defs/__schema9"
        }
      ],
      "id": "Duration"
    },
    "__schema7": {
      "type": "string"
    },
    "__schema8": {
      "type": "number",
      "const": -1
    },
    "__schema9": {
      "type": "number",
      "const": 0
    }
  }
}
