{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "datafeed_id": {
      "$ref": "#/$defs/__schema0"
    },
    "allow_no_match": {
      "$ref": "#/$defs/__schema1"
    },
    "force": {
      "$ref": "#/$defs/__schema3"
    },
    "timeout": {
      "$ref": "#/$defs/__schema5"
    },
    "close_job": {
      "$ref": "#/$defs/__schema10"
    }
  },
  "required": [
    "datafeed_id"
  ],
  "additionalProperties": false,
  "id": "MlStopDatafeedRequest",
  "$defs": {
    "__schema0": {
      "description": "Identifier for the datafeed. You can stop multiple datafeeds in a single API request by using a comma-separated list of datafeeds or a wildcard expression. You can close all datafeeds by using `_all` or by specifying `*` as the identifier.",
      "$ref": "#/$defs/Id"
    },
    "Id": {
      "type": "string",
      "id": "Id"
    },
    "__schema1": {
      "$ref": "#/$defs/__schema2"
    },
    "__schema2": {
      "type": "boolean",
      "description": "Refer to the description for the `allow_no_match` query parameter."
    },
    "__schema3": {
      "$ref": "#/$defs/__schema4"
    },
    "__schema4": {
      "type": "boolean",
      "description": "Refer to the description for the `force` query parameter."
    },
    "__schema5": {
      "$ref": "#/$defs/__schema6"
    },
    "__schema6": {
      "description": "Refer to the description for the `timeout` query parameter.",
      "$ref": "#/$defs/Duration"
    },
    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema7"
        },
        {
          "$ref": "#/$defs/__schema8"
        },
        {
          "$ref": "#/$defs/__schema9"
        }
      ],
      "id": "Duration"
    },
    "__schema7": {
      "type": "string"
    },
    "__schema8": {
      "type": "number",
      "const": -1
    },
    "__schema9": {
      "type": "number",
      "const": 0
    },
    "__schema10": {
      "$ref": "#/$defs/__schema11"
    },
    "__schema11": {
      "type": "boolean",
      "description": "Refer to the description for the `close_job` query parameter."
    }
  }
}
