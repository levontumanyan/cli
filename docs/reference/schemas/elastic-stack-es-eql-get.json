{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "#/$defs/__schema0"
    },
    "keep_alive": {
      "$ref": "#/$defs/__schema1"
    },
    "wait_for_completion_timeout": {
      "$ref": "#/$defs/__schema6"
    }
  },
  "required": [
    "id"
  ],
  "additionalProperties": false,
  "id": "EqlGetRequest",
  "$defs": {
    "__schema0": {
      "description": "Identifier for the search.",
      "$ref": "#/$defs/Id"
    },
    "Id": {
      "type": "string",
      "id": "Id"
    },
    "__schema1": {
      "$ref": "#/$defs/__schema2"
    },
    "__schema2": {
      "description": "Period for which the search and its results are stored on the cluster. Defaults to the keep_alive value set by the search’s EQL search API request.",
      "$ref": "#/$defs/Duration"
    },
    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema3"
        },
        {
          "$ref": "#/$defs/__schema4"
        },
        {
          "$ref": "#/$defs/__schema5"
        }
      ],
      "id": "Duration"
    },
    "__schema3": {
      "type": "string"
    },
    "__schema4": {
      "type": "number",
      "const": -1
    },
    "__schema5": {
      "type": "number",
      "const": 0
    },
    "__schema6": {
      "$ref": "#/$defs/__schema7"
    },
    "__schema7": {
      "description": "Timeout duration to wait for the request to finish. Defaults to no timeout, meaning the request waits for complete search results.",
      "$ref": "#/$defs/Duration"
    }
  }
}
