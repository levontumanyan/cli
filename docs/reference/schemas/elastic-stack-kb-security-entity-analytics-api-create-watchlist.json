  "type": "object",
  "properties": {
    "description": {
      "type": "string",
      "description": "Description of the watchlist"
    },
    "entitySources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema0"
      },
      "description": "Optional entity sources to create and link to the watchlist"
