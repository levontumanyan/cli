      "$ref": "#/$defs/__schema0"
    },
    "size": {
      "$ref": "#/$defs/__schema2"
    },
    "status": {
      "$ref": "#/$defs/__schema4"
    },
    "connector_id": {
      "$ref": "#/$defs/__schema6"
    },
    "job_type": {
      "$ref": "#/$defs/__schema8"
    }
  },
  "additionalProperties": false,
