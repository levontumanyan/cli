    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema5"
        },
        {
          "$ref": "#/$defs/__schema6"
        },
        {
          "$ref": "#/$defs/__schema7"
        }
      ],
      "id": "Duration"
    },
    "__schema5": {
      "type": "string"
    },
    "__schema6": {
      "type": "number",
      "const": -1
    },
    "__schema7": {
      "type": "number",
      "const": 0
