{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "$ref": "#/$defs/__schema0"
    },
    "master_timeout": {
      "$ref": "#/$defs/__schema1"
    },
    "wait_for_completion": {
      "$ref": "#/$defs/__schema6"
    }
  },
  "required": [
    "name"
  ],
  "additionalProperties": false,
  "id": "EnrichExecutePolicyRequest",
  "$defs": {
    "__schema0": {
      "description": "Enrich policy to execute.",
      "$ref": "#/$defs/Name"
    },
    "Name": {
      "type": "string",
      "id": "Name"
    },
    "__schema1": {
      "$ref": "#/$defs/__schema2"
    },
    "__schema2": {
      "description": "Period to wait for a connection to the master node.",
      "$ref": "#/$defs/Duration"
    },
    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema3"
        },
        {
          "$ref": "#/$defs/__schema4"
        },
        {
          "$ref": "#/$defs/__schema5"
        }
      ],
      "id": "Duration"
    },
    "__schema3": {
      "type": "string"
    },
    "__schema4": {
      "type": "number",
      "const": -1
    },
    "__schema5": {
      "type": "number",
      "const": 0
    },
    "__schema6": {
      "$ref": "#/$defs/__schema7"
    },
    "__schema7": {
      "type": "boolean",
      "description": "If `true`, the request blocks other enrich policy execution requests until complete."
    }
  }
}
