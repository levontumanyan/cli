{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "#/$defs/__schema0"
    },
    "master_timeout": {
      "$ref": "#/$defs/__schema1"
    }
  },
  "required": [
    "id"
  ],
  "additionalProperties": false,
  "id": "GetScriptRequest",
  "$defs": {
    "__schema0": {
      "description": "The identifier for the stored script or search template.",
      "$ref": "#/$defs/Id"
    },
    "Id": {
      "type": "string",
      "id": "Id"
    },
    "__schema1": {
      "$ref": "#/$defs/__schema2"
    },
    "__schema2": {
      "description": "The period to wait for the master node. If the master node is not available before the timeout expires, the request fails and returns an error. It can also be set to `-1` to indicate that the request should never timeout.",
      "$ref": "#/$defs/Duration"
    },
    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema3"
        },
        {
          "$ref": "#/$defs/__schema4"
        },
        {
          "$ref": "#/$defs/__schema5"
        }
      ],
      "id": "Duration"
    },
    "__schema3": {
      "type": "string"
    },
    "__schema4": {
      "type": "number",
      "const": -1
    },
    "__schema5": {
      "type": "number",
      "const": 0
    }
  }
}
