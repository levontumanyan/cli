    },
    "Id": {
      "type": "string",
      "id": "Id"
    },
    "__schema2": {
      "$ref": "#/$defs/__schema3"
    },
    "__schema3": {
      "description": "Period to wait for a connection to the master node. If no response is received before the timeout expires, the request fails and returns an error.",
      "$ref": "#/$defs/Duration"
    },
    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema4"
        },
        {
          "$ref": "#/$defs/__schema5"
        },
        {
          "$ref": "#/$defs/__schema6"
        }
      ],
      "id": "Duration"
    },
    "__schema4": {
      "type": "string"
    },
    "__schema5": {
      "type": "number",
      "const": -1
    },
    "__schema6": {
      "type": "number",
      "const": 0
    },
    "__schema7": {
      "$ref": "#/$defs/__schema8"
    },
    "__schema8": {
      "type": "boolean",
      "description": "Return pipelines without their definitions"
    }
  }
