  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "#/$defs/__schema0"
    },
    "master_timeout": {
      "$ref": "#/$defs/__schema2"
    },
    "summary": {
      "$ref": "#/$defs/__schema7"
    }
