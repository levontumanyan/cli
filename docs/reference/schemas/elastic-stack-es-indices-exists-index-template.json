{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "$ref": "#/$defs/__schema0"
    },
    "local": {
      "$ref": "#/$defs/__schema1"
    },
    "flat_settings": {
      "$ref": "#/$defs/__schema3"
    },
    "master_timeout": {
      "$ref": "#/$defs/__schema5"
    }
  },
  "required": [
    "name"
  ],
  "additionalProperties": false,
  "id": "IndicesExistsIndexTemplateRequest",
  "$defs": {
    "__schema0": {
      "description": "Comma-separated list of index template names used to limit the request. Wildcard (*) expressions are supported.",
      "$ref": "#/$defs/Name"
    },
    "Name": {
      "type": "string",
      "id": "Name"
    },
    "__schema1": {
      "$ref": "#/$defs/__schema2"
    },
    "__schema2": {
      "type": "boolean",
      "description": "If true, the request retrieves information from the local node only. Defaults to false, which means information is retrieved from the master node."
    },
    "__schema3": {
      "$ref": "#/$defs/__schema4"
    },
    "__schema4": {
      "type": "boolean",
      "description": "If true, returns settings in flat format."
    },
    "__schema5": {
      "$ref": "#/$defs/__schema6"
    },
    "__schema6": {
      "description": "Period to wait for a connection to the master node. If no response is received before the timeout expires, the request fails and returns an error.",
      "$ref": "#/$defs/Duration"
    },
    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema7"
        },
        {
          "$ref": "#/$defs/__schema8"
        },
        {
          "$ref": "#/$defs/__schema9"
        }
      ],
      "id": "Duration"
    },
    "__schema7": {
      "type": "string"
    },
    "__schema8": {
      "type": "number",
      "const": -1
    },
    "__schema9": {
      "type": "number",
      "const": 0
    }
  }
}
