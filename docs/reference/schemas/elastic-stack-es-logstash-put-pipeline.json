{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "#/$defs/__schema0"
    },
    "pipeline": {
      "$ref": "#/$defs/__schema1"
    }
  },
  "required": [
    "id"
  ],
  "additionalProperties": false,
  "id": "LogstashPutPipelineRequest",
  "$defs": {
    "__schema0": {
      "description": "An identifier for the pipeline. Pipeline IDs must begin with a letter or underscore and contain only letters, underscores, dashes, hyphens and numbers.",
      "$ref": "#/$defs/Id"
    },
    "Id": {
      "type": "string",
      "id": "Id"
    },
    "__schema1": {
      "$ref": "#/$defs/LogstashPipeline"
    },
    "LogstashPipeline": {
      "type": "object",
      "properties": {
        "description": {
          "$ref": "#/$defs/__schema2"
        },
        "last_modified": {
          "$ref": "#/$defs/__schema3"
        },
        "pipeline": {
          "$ref": "#/$defs/__schema6"
        },
        "pipeline_metadata": {
          "$ref": "#/$defs/__schema7"
        },
        "pipeline_settings": {
          "$ref": "#/$defs/__schema10"
        },
        "username": {
          "$ref": "#/$defs/__schema17"
        }
      },
      "required": [
        "description",
        "last_modified",
        "pipeline",
        "pipeline_metadata",
        "pipeline_settings",
        "username"
      ],
      "additionalProperties": false,
      "id": "LogstashPipeline"
    },
    "__schema2": {
      "type": "string",
      "description": "A description of the pipeline. This description is not used by Elasticsearch or Logstash."
    },
    "__schema3": {
      "description": "The date the pipeline was last updated. It must be in the `yyyy-MM-dd'T'HH:mm:ss.SSSZZ` strict_date_time format.",
      "$ref": "#/$defs/DateTime"
    },
    "DateTime": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema4"
        },
        {
          "$ref": "#/$defs/__schema5"
        }
      ],
      "id": "DateTime"
    },
    "__schema4": {
      "type": "string"
    },
    "__schema5": {
      "$ref": "#/$defs/EpochTime"
    },
    "EpochTime": {
      "id": "EpochTime"
    },
    "__schema6": {
      "type": "string",
      "description": "The configuration for the pipeline."
    },
    "__schema7": {
      "description": "Optional metadata about the pipeline, which can have any contents. This metadata is not generated or used by Elasticsearch or Logstash.",
      "$ref": "#/$defs/LogstashPipelineMetadata"
    },
    "__schema8": {
      "type": "string"
    },
    "__schema9": {
      "type": "string"
    },
    "LogstashPipelineMetadata": {
      "type": "object",
      "properties": {
        "type": {
          "$ref": "#/$defs/__schema8"
        },
        "version": {
          "$ref": "#/$defs/__schema9"
        }
      },
      "required": [
        "type",
        "version"
      ],
      "additionalProperties": false,
      "id": "LogstashPipelineMetadata"
    },
    "__schema10": {
      "description": "Settings for the pipeline. It supports only flat keys in dot notation.",
      "$ref": "#/$defs/LogstashPipelineSettings"
    },
    "__schema11": {
      "description": "The number of workers that will, in parallel, execute the filter and output stages of the pipeline.",
      "$ref": "#/$defs/integer"
    },
    "integer": {
      "type": "number",
      "id": "integer"
    },
    "__schema12": {
      "description": "The maximum number of events an individual worker thread will collect from inputs before attempting to execute its filters and outputs.",
      "$ref": "#/$defs/integer"
    },
    "__schema13": {
      "description": "When creating pipeline event batches, how long in milliseconds to wait for each event before dispatching an undersized batch to pipeline workers.",
      "$ref": "#/$defs/integer"
    },
    "__schema14": {
      "type": "string",
      "description": "The internal queuing model to use for event buffering."
    },
    "__schema15": {
      "type": "string",
      "description": "The total capacity of the queue (`queue.type: persisted`) in number of bytes."
    },
    "__schema16": {
      "description": "The maximum number of written events before forcing a checkpoint when persistent queues are enabled (`queue.type: persisted`).",
      "$ref": "#/$defs/integer"
    },
    "LogstashPipelineSettings": {
      "type": "object",
      "properties": {
        "pipeline.workers": {
          "$ref": "#/$defs/__schema11"
        },
        "pipeline.batch.size": {
          "$ref": "#/$defs/__schema12"
        },
        "pipeline.batch.delay": {
          "$ref": "#/$defs/__schema13"
        },
        "queue.type": {
          "$ref": "#/$defs/__schema14"
        },
        "queue.max_bytes": {
          "$ref": "#/$defs/__schema15"
        },
        "queue.checkpoint.writes": {
          "$ref": "#/$defs/__schema16"
        }
      },
      "required": [
        "pipeline.workers",
        "pipeline.batch.size",
        "pipeline.batch.delay",
        "queue.type",
        "queue.max_bytes",
        "queue.checkpoint.writes"
      ],
      "additionalProperties": false,
      "id": "LogstashPipelineSettings"
    },
    "__schema17": {
      "type": "string",
      "description": "The user who last updated the pipeline."
    }
  }
}
