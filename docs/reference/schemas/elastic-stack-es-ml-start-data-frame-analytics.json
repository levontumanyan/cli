{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "#/$defs/__schema0"
    },
    "timeout": {
      "$ref": "#/$defs/__schema1"
    }
  },
  "required": [
    "id"
  ],
  "additionalProperties": false,
  "id": "MlStartDataFrameAnalyticsRequest",
  "$defs": {
