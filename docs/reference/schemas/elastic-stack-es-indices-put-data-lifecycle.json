{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "$ref": "#/$defs/__schema0"
    },
    "expand_wildcards": {
      "$ref": "#/$defs/__schema3"
    },
    "master_timeout": {
      "$ref": "#/$defs/__schema6"
    },
    "timeout": {
      "$ref": "#/$defs/__schema11"
    },
    "data_retention": {
      "$ref": "#/$defs/__schema13"
    },
    "downsampling": {
      "$ref": "#/$defs/__schema15"
    },
    "downsampling_method": {
      "$ref": "#/$defs/__schema19"
    },
    "enabled": {
      "$ref": "#/$defs/__schema21"
    }
  },
  "required": [
    "name"
  ],
  "additionalProperties": false,
  "id": "IndicesPutDataLifecycleRequest",
  "$defs": {
    "__schema0": {
      "description": "Comma-separated list of data streams used to limit the request. Supports wildcards (`*`). To target all data streams use `*` or `_all`.",
      "$ref": "#/$defs/DataStreamNames"
    },
    "DataStreamNames": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema1"
        },
        {
          "$ref": "#/$defs/__schema2"
        }
      ],
      "id": "DataStreamNames"
    },
    "__schema1": {
      "$ref": "#/$defs/DataStreamName"
    },
    "DataStreamName": {
      "type": "string",
      "id": "DataStreamName"
    },
    "__schema2": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DataStreamName"
      }
    },
    "__schema3": {
      "$ref": "#/$defs/__schema4"
    },
    "__schema4": {
      "description": "Type of data stream that wildcard patterns can match. Supports comma-separated values, such as `open,hidden`.",
      "$ref": "#/$defs/ExpandWildcards"
    },
    "ExpandWildcards": {
      "anyOf": [
        {
          "$ref": "#/$defs/ExpandWildcard"
        },
        {
          "$ref": "#/$defs/__schema5"
        }
      ],
      "id": "ExpandWildcards"
    },
    "ExpandWildcard": {
      "type": "string",
      "enum": [
        "all",
        "open",
        "closed",
        "hidden",
        "none"
      ],
      "id": "ExpandWildcard"
    },
    "__schema5": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ExpandWildcard"
      }
    },
    "__schema6": {
      "$ref": "#/$defs/__schema7"
    },
    "__schema7": {
      "description": "Period to wait for a connection to the master node. If no response is received before the timeout expires, the request fails and returns an error.",
      "$ref": "#/$defs/Duration"
    },
    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema8"
        },
        {
          "$ref": "#/$defs/__schema9"
        },
        {
          "$ref": "#/$defs/__schema10"
        }
      ],
      "id": "Duration"
    },
    "__schema8": {
      "type": "string"
    },
    "__schema9": {
      "type": "number",
      "const": -1
    },
    "__schema10": {
      "type": "number",
      "const": 0
    },
    "__schema11": {
      "$ref": "#/$defs/__schema12"
    },
    "__schema12": {
      "description": "Period to wait for a response. If no response is received before the timeout expires, the request fails and returns an error.",
      "$ref": "#/$defs/Duration"
    },
    "__schema13": {
      "$ref": "#/$defs/__schema14"
    },
    "__schema14": {
      "description": "If defined, every document added to this data stream will be stored at least for this time frame. Any time after this duration the document could be deleted. When empty, every document in this data stream will be stored indefinitely.",
      "$ref": "#/$defs/Duration"
    },
    "__schema15": {
      "$ref": "#/$defs/__schema16"
    },
    "__schema16": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/IndicesDownsamplingRound"
      },
      "description": "The downsampling configuration to execute for the managed backing index after rollover."
    },
    "IndicesDownsamplingRound": {
      "type": "object",
      "properties": {
        "after": {
          "$ref": "#/$defs/__schema17"
        },
        "fixed_interval": {
          "$ref": "#/$defs/__schema18"
        }
      },
      "required": [
        "after",
        "fixed_interval"
      ],
      "additionalProperties": false,
      "id": "IndicesDownsamplingRound"
    },
    "__schema17": {
      "description": "The duration since rollover when this downsampling round should execute",
      "$ref": "#/$defs/Duration"
    },
    "__schema18": {
      "description": "The downsample interval.",
      "$ref": "#/$defs/DurationLarge"
    },
    "DurationLarge": {
      "type": "string",
      "id": "DurationLarge"
    },
    "__schema19": {
      "$ref": "#/$defs/__schema20"
    },
    "__schema20": {
      "description": "The method used to downsample the data. There are two options `aggregate` and `last_value`. It requires `downsampling` to be defined. Defaults to `aggregate`.",
      "$ref": "#/$defs/IndicesSamplingMethod"
    },
    "IndicesSamplingMethod": {
      "type": "string",
      "enum": [
        "aggregate",
        "last_value"
      ],
      "id": "IndicesSamplingMethod"
    },
    "__schema21": {
      "$ref": "#/$defs/__schema22"
    },
    "__schema22": {
      "type": "boolean",
      "description": "If defined, it turns data stream lifecycle on/off (`true`/`false`) for this data stream. A data stream lifecycle that's disabled (enabled: `false`) will have no effect on the data stream."
    }
  }
}
