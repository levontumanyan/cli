{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "datafeed_id": {
      "$ref": "#/$defs/__schema0"
    },
    "end": {
      "$ref": "#/$defs/__schema1"
    },
    "start": {
      "$ref": "#/$defs/__schema5"
    },
    "timeout": {
      "$ref": "#/$defs/__schema7"
    }
  },
  "required": [
    "datafeed_id"
  ],
  "additionalProperties": false,
  "id": "MlStartDatafeedRequest",
  "$defs": {
    "__schema0": {
      "description": "A numerical character string that uniquely identifies the datafeed. This identifier can contain lowercase alphanumeric characters (a-z and 0-9), hyphens, and underscores. It must start and end with alphanumeric characters.",
      "$ref": "#/$defs/Id"
    },
    "Id": {
      "type": "string",
      "id": "Id"
    },
    "__schema1": {
      "$ref": "#/$defs/__schema2"
    },
    "__schema2": {
      "description": "Refer to the description for the `end` query parameter.",
      "$ref": "#/$defs/DateTime"
    },
    "DateTime": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema3"
        },
        {
          "$ref": "#/$defs/__schema4"
        }
      ],
      "id": "DateTime"
    },
    "__schema3": {
      "type": "string"
    },
    "__schema4": {
      "$ref": "#/$defs/EpochTime"
    },
    "EpochTime": {
      "id": "EpochTime"
    },
    "__schema5": {
      "$ref": "#/$defs/__schema6"
    },
    "__schema6": {
      "description": "Refer to the description for the `start` query parameter.",
      "$ref": "#/$defs/DateTime"
    },
    "__schema7": {
      "$ref": "#/$defs/__schema8"
    },
    "__schema8": {
      "description": "Refer to the description for the `timeout` query parameter.",
      "$ref": "#/$defs/Duration"
    },
    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema9"
        },
        {
          "$ref": "#/$defs/__schema10"
        },
        {
          "$ref": "#/$defs/__schema11"
        }
      ],
      "id": "Duration"
    },
    "__schema9": {
      "type": "string"
    },
    "__schema10": {
      "type": "number",
      "const": -1
    },
    "__schema11": {
      "type": "number",
      "const": 0
    }
  }
}
