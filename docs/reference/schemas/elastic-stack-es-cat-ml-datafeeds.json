{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "datafeed_id": {
      "$ref": "#/$defs/__schema0"
    },
    "allow_no_match": {
      "$ref": "#/$defs/__schema2"
    },
    "h": {
      "$ref": "#/$defs/__schema4"
    },
    "s": {
      "$ref": "#/$defs/__schema7"
    }
  },
  "additionalProperties": false,
  "id": "CatMlDatafeedsRequest",
  "$defs": {
    "__schema0": {
      "$ref": "#/$defs/__schema1"
    },
    "__schema1": {
      "description": "A numerical character string that uniquely identifies the datafeed.",
      "$ref": "#/$defs/Id"
    },
    "Id": {
      "type": "string",
      "id": "Id"
    },
    "__schema2": {
      "$ref": "#/$defs/__schema3"
    },
    "__schema3": {
      "type": "boolean",
      "description": "Specifies what to do when the request: * Contains wildcard expressions and there are no datafeeds that match. * Contains the `_all` string or no identifiers and there are no matches. * Contains wildcard expressions and there are only partial matches. If `true`, the API returns an empty datafeeds array when there are no matches and the subset of results when there are partial matches. If `false`, the API returns a 404 status code when there are no matches or only partial matches."
    },
    "__schema4": {
      "$ref": "#/$defs/__schema5"
    },
    "__schema5": {
      "description": "Comma-separated list of column names to display.",
      "$ref": "#/$defs/CatCatDatafeedColumns"
    },
    "CatCatDatafeedColumn": {
      "type": "string",
      "enum": [
        "ae",
        "assignment_explanation",
        "bc",
        "buckets.count",
        "bucketsCount",
        "id",
        "na",
        "node.address",
        "nodeAddress",
        "ne",
        "node.ephemeral_id",
        "nodeEphemeralId",
        "ni",
        "node.id",
        "nodeId",
        "nn",
        "node.name",
        "nodeName",
        "sba",
        "search.bucket_avg",
        "searchBucketAvg",
        "sc",
        "search.count",
        "searchCount",
        "seah",
        "search.exp_avg_hour",
        "searchExpAvgHour",
        "st",
        "search.time",
        "searchTime",
        "s",
        "state"
      ],
      "id": "CatCatDatafeedColumn"
    },
    "__schema6": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CatCatDatafeedColumn"
      }
    },
    "CatCatDatafeedColumns": {
      "anyOf": [
        {
          "$ref": "#/$defs/CatCatDatafeedColumn"
        },
        {
          "$ref": "#/$defs/__schema6"
        }
      ],
      "id": "CatCatDatafeedColumns"
    },
    "__schema7": {
      "$ref": "#/$defs/__schema8"
    },
    "__schema8": {
      "description": "Comma-separated list of column names or column aliases used to sort the response.",
      "$ref": "#/$defs/CatCatDatafeedColumns"
    }
  }
}
