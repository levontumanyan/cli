{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "$ref": "#/$defs/__schema0"
    },
    "flat_settings": {
      "$ref": "#/$defs/__schema2"
    },
    "settings_filter": {
      "$ref": "#/$defs/__schema4"
    },
    "include_defaults": {
      "$ref": "#/$defs/__schema8"
    },
    "local": {
      "$ref": "#/$defs/__schema10"
    },
    "master_timeout": {
      "$ref": "#/$defs/__schema12"
    }
  },
  "additionalProperties": false,
  "id": "ClusterGetComponentTemplateRequest",
  "$defs": {
    "__schema0": {
      "$ref": "#/$defs/__schema1"
    },
    "__schema1": {
      "description": "Name of component template to retrieve. Wildcard (`*`) expressions are supported.",
      "$ref": "#/$defs/Name"
    },
    "Name": {
      "type": "string",
      "id": "Name"
    },
    "__schema2": {
      "$ref": "#/$defs/__schema3"
    },
    "__schema3": {
      "type": "boolean",
      "description": "If `true`, returns settings in flat format."
    },
    "__schema4": {
      "$ref": "#/$defs/__schema5"
    },
    "__schema5": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema6"
        },
        {
          "$ref": "#/$defs/__schema7"
        }
      ],
      "description": "Filter out results, for example to filter out sensitive information. Supports wildcards or full settings keys"
    },
    "__schema6": {
      "type": "string"
    },
    "__schema7": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "__schema8": {
      "$ref": "#/$defs/__schema9"
    },
    "__schema9": {
      "type": "boolean",
      "description": "Return all default configurations for the component template"
    },
    "__schema10": {
      "$ref": "#/$defs/__schema11"
    },
    "__schema11": {
      "type": "boolean",
      "description": "If `true`, the request retrieves information from the local node only. If `false`, information is retrieved from the master node."
    },
    "__schema12": {
      "$ref": "#/$defs/__schema13"
    },
    "__schema13": {
      "description": "Period to wait for a connection to the master node. If no response is received before the timeout expires, the request fails and returns an error.",
      "$ref": "#/$defs/Duration"
    },
    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema14"
        },
        {
          "$ref": "#/$defs/__schema15"
        },
        {
          "$ref": "#/$defs/__schema16"
        }
      ],
      "id": "Duration"
    },
    "__schema14": {
      "type": "string"
    },
    "__schema15": {
      "type": "number",
      "const": -1
    },
    "__schema16": {
      "type": "number",
      "const": 0
    }
  }
}
