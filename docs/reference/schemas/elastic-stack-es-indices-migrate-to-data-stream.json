    },
    "Duration": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema3"
        },
        {
          "$ref": "#/$defs/__schema4"
        },
        {
          "$ref": "#/$defs/__schema5"
        }
      ],
      "id": "Duration"
    },
    "__schema3": {
      "type": "string"
    },
    "__schema4": {
      "type": "number",
      "const": -1
    },
    "__schema5": {
      "type": "number",
      "const": 0
    },
    "__schema6": {
      "$ref": "#/$defs/__schema7"
    },
    "__schema7": {
      "description": "Period to wait for a response. If no response is received before the timeout expires, the request fails and returns an error.",
