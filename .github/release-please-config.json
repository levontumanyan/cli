{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "draft-pull-request": true,
  "always-update": true,
  "bootstrap-sha": "b056a344e6b9b27e09bb2b6270be2e6b8c5bf2fc",
  "packages" : {
    ".": {
        "extra-files": [
            "src/cli.ts"
        ],
        "include-component-in-tag": false
    },
    "packages/es-schemas": {
        "component": "es-schemas",
        "release-type": "node"
    }
  },
  "plugins": [
    {
        "type": "sentence-case"
    }
  ]
}
